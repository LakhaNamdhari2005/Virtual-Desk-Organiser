// ═════════════════════════════════════════════
//  BATTERY TASK
// ═════════════════════════════════════════════
void taskBattery(void* pvParameters) {
  dbg("TASK_BAT", "Started");
  vTaskDelay(pdMS_TO_TICKS(2000));

  for (;;) {
    long adcSum = 0;
    for (int i = 0; i < 10; i++) {
      adcSum += analogRead(BAT_ADC);
      vTaskDelay(pdMS_TO_TICKS(20));
    }
    int adcVal = adcSum / 10;

    // ✅ ESP32-S3 ADC with 11dB attenuation:
    // Full scale = 3.1V (not 3.3V) — hardware characteristic
    // Voltage divider 100k + 47k:
    // Vbat = Vadc × (100+47)/47
    // But for 600mAh LiPo: full=4.2V, empty=3.0V
    // At full: Vadc = 4.2 × 47/147 = 1.34V → ADC ≈ 1768
    // At empty: Vadc = 3.0 × 47/147 = 0.96V → ADC ≈ 1267

    // ✅ Use direct ADC mapping — calibrated for your divider
    // Map ADC 1267(empty) to 1768(full) → 0% to 100%
    float pct = ((float)(adcVal - 1267) / (1768.0f - 1267.0f)) * 100.0f;
    if (pct > 100.0f) pct = 100.0f;
    if (pct < 0.0f)   pct = 0.0f;

    // Also calculate voltage for debug
    float vadc = (adcVal / 4095.0f) * 3.1f;  // 3.1V full scale for 11dB
    float vbat = vadc * (147.0f / 47.0f);

    dbgf("TASK_BAT", "ADC:%d  Vadc:%.2fV  Vbat:%.2fV  Pct:%.0f%%",
         adcVal, vadc, vbat, pct);

    if (pct > 70.0f) {
      digitalWrite(LED_HIGH, HIGH);
      digitalWrite(LED_MID,  LOW);
      digitalWrite(LED_LOW,  LOW);
      dbg("TASK_BAT", "Battery: HIGH (green)");
    } else if (pct > 30.0f) {
      digitalWrite(LED_HIGH, LOW);
      digitalWrite(LED_MID,  HIGH);
      digitalWrite(LED_LOW,  LOW);
      dbg("TASK_BAT", "Battery: MID (yellow)");
    } else {
      dbg("TASK_BAT", "Battery: LOW (red blinking)");
      for (int b = 0; b < 3; b++) {
        digitalWrite(LED_HIGH, LOW);
        digitalWrite(LED_MID,  LOW);
        digitalWrite(LED_LOW,  HIGH);
        vTaskDelay(pdMS_TO_TICKS(300));
        digitalWrite(LED_LOW,  LOW);
        vTaskDelay(pdMS_TO_TICKS(300));
      }
    }

    vTaskDelay(pdMS_TO_TICKS(30000));
  }
}

