// ═════════════════════════════════════════════
//  TEXT HELPERS
// ═════════════════════════════════════════════
void drawTextWrapped(const char* text, int x, int y, int maxWidth) {
  display.setFont(&FreeMonoBold18pt7b);
  display.setTextColor(GxEPD_BLACK);
  String txt = String(text), line = "", word = "";
  for (int i = 0; i <= (int)txt.length(); i++) {
    char c = (i < (int)txt.length()) ? txt[i] : ' ';
    if (c == ' ') {
      String testLine = line + word + " ";
      int16_t x1, y1; uint16_t w, h;
      display.getTextBounds(testLine, 0, 0, &x1, &y1, &w, &h);
      if (w > maxWidth && line.length() > 0) {
        display.setCursor(x, y); display.print(line);
        line = word + " "; y += 45;
      } else { line = testLine; }
      word = "";
    } else { word += c; }
  }
  if (line.length() > 0) { display.setCursor(x, y); display.print(line); }
}

