// ═════════════════════════════════════════════
void dbg(const char* tag, const char* msg) {
  Serial.printf("[%8lu] [%-12s] %s\n", millis(), tag, msg);
}
void dbgf(const char* tag, const char* fmt, ...) {
  char buf[256];
  va_list args;
  va_start(args, fmt);
  vsnprintf(buf, sizeof(buf), fmt, args);
  va_end(args);
  Serial.printf("[%8lu] [%-12s] %s\n", millis(), tag, buf);
}

