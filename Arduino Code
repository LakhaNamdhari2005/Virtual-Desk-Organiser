// ✅ Connection events
class MyServerCallbacks : public BLEServerCallbacks {
  void onConnect(BLEServer* pServer) override {
    bleConnected = true;
    dbg("BLE", "Client connected!");
    // Send welcome status
    if (pStatusChar) {
      pStatusChar->setValue("SmartDesk connected!");
      pStatusChar->notify();
    }
  }
  void onDisconnect(BLEServer* pServer) override {
    bleConnected = false;
    dbg("BLE", "Client disconnected — restarting advertising");
    // ✅ Restart advertising so device is discoverable again
    BLEDevice::startAdvertising();
  }
};

// ✅ Message received from phone
class MsgCharCallbacks : public BLECharacteristicCallbacks {
  void onWrite(BLECharacteristic* pCharacteristic) override {
    String val = pCharacteristic->getValue().c_str();
    val.trim();
    if (val.length() == 0) return;

    Serial.println("════════════════════════════════");
    Serial.println("📱 BLE MESSAGE RECEIVED!");
    Serial.print("   Raw text : ");
    Serial.println(val);

    // ✅ Try getLocalTime with retry — BLE callback runs fast
    char timeStr[16] = "??:??";
    struct tm timeinfo;
    // ✅ Retry up to 3 times with small delay
    for (int i = 0; i < 3; i++) {
      if (getLocalTime(&timeinfo, 1000)) { // 1000ms timeout
        strftime(timeStr, sizeof(timeStr), "%H:%M", &timeinfo);
        break;
      }
      delay(100);
    }

    String formatted = "\"" + val + "\" at " + String(timeStr) + " (BT)";

    Serial.print("   Time     : ");
    Serial.println(timeStr);
    Serial.print("   Formatted: ");
    Serial.println(formatted);
    Serial.println("════════════════════════════════");

    xSemaphoreTake(dataMutex, portMAX_DELAY);
    strlcpy(deskData.messageText, formatted.c_str(), 256);
    xSemaphoreGive(dataMutex);

    bleNewMessage = true;

    if (pStatusChar) {
      pStatusChar->setValue("OK: " + val.substring(0, 20));
      pStatusChar->notify();
    }
  }
};

// ═════════════════════════════════════════════
//  BLE INIT
// ═════════════════════════════════════════════
void initBLE() {
  dbg("BLE", "Initializing BLE...");
  BLEDevice::init(BLE_DEVICE_NAME);

  pServer = BLEDevice::createServer();
  pServer->setCallbacks(new MyServerCallbacks());

  BLEService* pService = pServer->createService(BLE_SERVICE_UUID);

  // ── Message characteristic (phone → ESP32) ──
  pMsgChar = pService->createCharacteristic(
    BLE_MSG_CHAR_UUID,
    BLECharacteristic::PROPERTY_WRITE |
    BLECharacteristic::PROPERTY_WRITE_NR   // no-response write = faster
  );
  pMsgChar->setCallbacks(new MsgCharCallbacks());

  // ── Status characteristic (ESP32 → phone, notify) ──
  pStatusChar = pService->createCharacteristic(
    BLE_STATUS_CHAR_UUID,
    BLECharacteristic::PROPERTY_READ  |
    BLECharacteristic::PROPERTY_NOTIFY
  );
  pStatusChar->addDescriptor(new BLE2902());
  pStatusChar->setValue("SmartDesk Ready");

  pService->start();

  // ── Advertising ──
  BLEAdvertising* pAdvertising = BLEDevice::getAdvertising();
  pAdvertising->addServiceUUID(BLE_SERVICE_UUID);
  pAdvertising->setScanResponse(true);
  pAdvertising->setMinPreferred(0x06);
  BLEDevice::startAdvertising();

  dbg("BLE", "BLE started — advertising as 'SmartDesk'");
}

// ═════════════════════════════════════════════
//  ISRs
// ═════════════════════════════════════════════
void IRAM_ATTR isrBtnNext() {
  unsigned long now = millis();
  if (now - lastBtnNextTime > DEBOUNCE_MS) {
    if (now - prevBtnNextPress < DOUBLE_PRESS_MS) {
      doublePressNext = true;
    } else {
      lastActivityTime     = now;
      pirSwitchedToMessage = false;
      btnNextPressed       = true;
      abortRefresh         = true;
      BaseType_t xHigherPriorityTaskWoken = pdFALSE;
      DisplayCommand cmd = CMD_DRAW_PAGE2;
      xQueueSendFromISR(displayQueue, &cmd, &xHigherPriorityTaskWoken);
      portYIELD_FROM_ISR(xHigherPriorityTaskWoken);
    }
    prevBtnNextPress = now;
    lastBtnNextTime  = now;
  }
}

void IRAM_ATTR isrBtnPrev() {
  unsigned long now = millis();
  if (now - lastBtnPrevTime > DEBOUNCE_MS) {
    if (now - prevBtnPrevPress < DOUBLE_PRESS_MS) {
      doublePressPrev = true;
    } else {
      lastActivityTime     = now;
      pirSwitchedToMessage = false;
      btnPrevPressed       = true;
      abortRefresh         = true;
      BaseType_t xHigherPriorityTaskWoken = pdFALSE;
      DisplayCommand cmd = CMD_DRAW_PAGE1;
      xQueueSendFromISR(displayQueue, &cmd, &xHigherPriorityTaskWoken);
      portYIELD_FROM_ISR(xHigherPriorityTaskWoken);
    }
    prevBtnPrevPress = now;
    lastBtnPrevTime  = now;
  }
}

// ═════════════════════════════════════════════
//  WIFI
// ═════════════════════════════════════════════
void connectWiFi() {
  if (WiFi.status() == WL_CONNECTED) { dbg("WIFI", "Already connected"); return; }
  dbgf("WIFI", "Connecting to: %s", ssid);
  WiFi.disconnect(true);
  vTaskDelay(pdMS_TO_TICKS(500));
  WiFi.mode(WIFI_STA);
  WiFi.setSleep(false);
  WiFi.setTxPower(WIFI_POWER_19_5dBm);
  WiFi.begin(ssid, password);
  int retries = 0;
  while (WiFi.status() != WL_CONNECTED && retries < 40) {
    vTaskDelay(pdMS_TO_TICKS(500));
    dbgf("WIFI", "Attempt %d/40 status:%d", ++retries, WiFi.status());
  }
  if (WiFi.status() == WL_CONNECTED)
    dbgf("WIFI", "Connected! IP:%s RSSI:%d",
         WiFi.localIP().toString().c_str(), WiFi.RSSI());
  else
    dbg("WIFI", "ERROR — Failed");
}

