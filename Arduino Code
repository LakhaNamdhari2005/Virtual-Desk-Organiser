// ═════════════════════════════════════════════
//  FETCH
// ═════════════════════════════════════════════
bool fetchAndStore() {
  dbg("FETCH", "===== START =====");
  unsigned long t0 = millis();
  xSemaphoreTake(wifiMutex, portMAX_DELAY);
  connectWiFi();
  if (WiFi.status() != WL_CONNECTED) {
    dbg("FETCH", "ERROR — WiFi not connected");
    xSemaphoreGive(wifiMutex); return false;
  }
  HTTPClient http;
  http.begin(apiURL);
  http.setTimeout(10000);
  http.setConnectTimeout(5000);
  int code = http.GET();
  if (code != 200) {
    dbgf("FETCH", "ERROR code:%d", code);
    http.end(); xSemaphoreGive(wifiMutex); return false;
  }
  String payload = http.getString();
  http.end();
  xSemaphoreGive(wifiMutex);

  StaticJsonDocument<8192> doc;
  if (deserializeJson(doc, payload)) { dbg("FETCH", "JSON ERR"); return false; }

  xSemaphoreTake(dataMutex, portMAX_DELAY);
  deskData.temperature = doc["weather"]["temp"].as<float>();
  strlcpy(deskData.weatherText, doc["weather"]["condition"].as<String>().c_str(), 64);
  strlcpy(deskData.city,        doc["weather"]["city"].as<String>().c_str(),      64);
  strlcpy(deskData.quoteText,   doc["quotes"].as<String>().c_str(),               512);
  snprintf(deskData.humidity,  16, "%d%%",    doc["weather"]["humidity"].as<int>());
  snprintf(deskData.windSpeed, 16, "%d km/h", doc["weather"]["wind"].as<int>());

  JsonArray alarms = doc["alarms"];
  deskData.alarmCount = 0;
  for (int i = 0; i < (int)alarms.size() && i < MAX_ALARMS; i++)
    strlcpy(deskData.alarmTime[deskData.alarmCount++], alarms[i].as<String>().c_str(), 16);

  JsonArray tasks = doc["tasks"];
  deskData.taskCount = 0;
  for (int i = 0; i < (int)tasks.size() && i < MAX_TASKS; i++) {
    strlcpy(deskData.tasks[deskData.taskCount].title, tasks[i]["title"].as<String>().c_str(), 128);
    deskData.tasks[deskData.taskCount].done = tasks[i]["done"].as<bool>();
    deskData.taskCount++;
  }

  JsonArray cal = doc["calendarEvents"];
  deskData.eventCount = 0;
  for (int i = 0; i < (int)cal.size() && deskData.eventCount < MAX_EVENTS; i++) {
    int dateNum = cal[i]["date"].as<int>();
    JsonArray evts = cal[i]["events"];
    for (int j = 0; j < (int)evts.size() && deskData.eventCount < MAX_EVENTS; j++) {
      deskData.events[deskData.eventCount].date = dateNum;
      strlcpy(deskData.events[deskData.eventCount].event, evts[j].as<String>().c_str(), 128);
      deskData.eventCount++;
    }
  }

  // ✅ Only overwrite messageText from API if NO BLE message present
  // BLE messages are preserved until next API message or reboot
  bool hasBLEMsg = (strstr(deskData.messageText, "(BT)") != nullptr);
  if (!hasBLEMsg) {
    JsonArray msgs = doc["deskMessages"];
    strlcpy(deskData.messageText, "No messages", 256);
    for (int i = msgs.size() - 1; i >= 0; i--) {
      JsonObject msg = msgs[i];
      if (!msg["isDesk"].as<bool>() && msg["text"].as<String>() != "Message received ") {
        String m = "\"" + msg["text"].as<String>() + "\" at " + msg["time"].as<String>();
        strlcpy(deskData.messageText, m.c_str(), 256);
        break;
      }
    }
  } else {
    dbg("FETCH", "BLE message present — keeping it, skipping API message");
  }

  deskData.dataReady = true;
  xSemaphoreGive(dataMutex);
  dbgf("FETCH", "===== DONE in %lu ms =====", millis() - t0);
  return true;
}

// ═════════════════════════════════════════════
//  TASK: PIR
// ═════════════════════════════════════════════
void taskPIR(void* pvParameters) {
  dbg("TASK_PIR", "Started");
  lastActivityTime = millis();
  for (;;) {
    int motion = digitalRead(PIR_PIN);
    if (motion == HIGH) {
      if (pirSwitchedToMessage) pirSwitchedToMessage = false;
      lastActivityTime = millis();
    } else {
      if ((millis() - lastActivityTime >= PIR_INACTIVITY_MS) && !pirSwitchedToMessage) {
        pirSwitchedToMessage = true;
        if (currentPage != 2) {
          currentPage = 2;
          DisplayCommand cmd = CMD_DRAW_PAGE3;
          xQueueSend(displayQueue, &cmd, 0);
        }
      }
    }
    vTaskDelay(pdMS_TO_TICKS(500));
  }
}

// ═════════════════════════════════════════════
//  TASK: API
// ═════════════════════════════════════════════
void taskAPI(void* pvParameters) {
  dbg("TASK_API", "Started");

  // ✅ Subscribe this task to watchdog with long timeout
  

  bool ok = false;
  while (!ok) {
    ok = fetchAndStore();
    if (!ok) {
      dbg("TASK_API", "Retry 5s");
      vTaskDelay(pdMS_TO_TICKS(5000));
    }
  }

  DisplayCommand cmd = CMD_DRAW_PAGE1;
  xQueueSend(displayQueue, &cmd, portMAX_DELAY);
  xTimerStart(timeRefreshTimer, 0);
  xTimerStart(apiRefreshTimer,  0);

  for (;;) {
    esp_task_wdt_reset(); // ✅ feed watchdog before suspend
    vTaskSuspend(NULL);
    esp_task_wdt_reset(); // ✅ feed watchdog after wakeup
    bool result = fetchAndStore();
    if (result && currentPage == 0) {
      DisplayCommand c = CMD_PARTIAL_PAGE1;
      xQueueSend(displayQueue, &c, 0);
    }
    if (bleNewMessage) {
      bleNewMessage = false;
      currentPage   = 2;
      DisplayCommand bc = CMD_DRAW_PAGE3;
      xQueueSend(displayQueue, &bc, 0);
    }
  }
}

// ═════════════════════════════════════════════
//  TASK: DISPLAY
// ═════════════════════════════════════════════
void taskDisplay(void* pvParameters) {
  dbg("TASK_DISP", "Started");
  for (;;) {
    // ✅ Check bleNewMessage even when idle
    if (bleNewMessage) {
      bleNewMessage = false;
      currentPage   = 2;
      dbg("TASK_DISP", "BLE message → drawing page 3");
      drawPage3();
      continue;
    }

    DisplayCommand cmd;
    if (xQueueReceive(displayQueue, &cmd, pdMS_TO_TICKS(500))) {
      dbgf("TASK_DISP", "CMD:%d page:%d", (int)cmd, currentPage);

      if (btnNextPressed || btnPrevPressed) {
        DisplayCommand discard;
        while (xQueueReceive(displayQueue, &discard, 0) == pdTRUE) {}
        if (btnNextPressed) {
          currentPage    = (currentPage + 1) % 4;
          btnNextPressed = false;
        } else {
          currentPage    = (currentPage - 1 < 0) ? 3 : currentPage - 1;
          btnPrevPressed = false;
        }
        cmd = (DisplayCommand)currentPage;
        abortRefresh = false;
      }

      switch (cmd) {
        case CMD_DRAW_PAGE1:
          currentPage = 0;
          if (!page1DrawnOnce || lastContentPage != 0) drawPage1Full();
          else drawPage1Partial();
          break;
        case CMD_PARTIAL_PAGE1:
          if (page1DrawnOnce) drawPage1Partial(); else drawPage1Full();
          break;
        case CMD_PARTIAL_TIME:
          refreshTimeBoxOnly();
          break;
        case CMD_DRAW_PAGE2:
          currentPage = 1; drawPage2(); break;
        case CMD_DRAW_PAGE3:
          currentPage = 2; drawPage3(); break;
        case CMD_DRAW_PAGE4:
          currentPage = 3; drawPage4(); break;
      }
    }
  }
}

// ═════════════════════════════════════════════
//  TASK: BUZZER
// ═════════════════════════════════════════════
void taskBuzzer(void* pvParameters) {
  dbg("TASK_BUZ", "Started");
  for (;;) {
    if (doublePressNext && isAlarmActive) {
      doublePressNext = false; isAlarmActive = false; alarmSnoozed = false;
      ledcWrite(BUZZER, 0); dbg("TASK_BUZ", "ALARM STOPPED");
    }
    if (doublePressPrev && isAlarmActive) {
      doublePressPrev = false; alarmSnoozed = true; snoozeStartTime = millis();
      ledcWrite(BUZZER, 0); dbg("TASK_BUZ", "ALARM SNOOZED 1 min");
    }
    if (alarmSnoozed && (millis() - snoozeStartTime >= 60000)) {
      alarmSnoozed = false; isAlarmActive = true; alarmStartTime = millis();
      dbg("TASK_BUZ", "SNOOZE EXPIRED — re-ring");
    }
    if (isAlarmActive && !alarmSnoozed) {
      unsigned long el = millis() - alarmStartTime;
      if (el < 60000) {
        ledcWrite(BUZZER, 127); vTaskDelay(pdMS_TO_TICKS(200));
        ledcWrite(BUZZER, 0);   vTaskDelay(pdMS_TO_TICKS(800));
      } else {
        isAlarmActive = false; ledcWrite(BUZZER, 0);
        dbg("TASK_BUZ", "Auto-ended");
        vTaskDelay(pdMS_TO_TICKS(100));
      }
    } else {
      if (doublePressNext) doublePressNext = false;
      if (doublePressPrev) doublePressPrev = false;
      vTaskDelay(pdMS_TO_TICKS(100));
    }
  }
}

// ═════════════════════════════════════════════
//  TASK: ALARM
// ═════════════════════════════════════════════
void taskAlarm(void* pvParameters) {
  dbg("TASK_ALM", "Started");
  for (;;) {
    struct tm timeinfo;
    if (getLocalTime(&timeinfo)) {
      char currentTime[10];
      strftime(currentTime, sizeof(currentTime), "%I:%M %p", &timeinfo);
      xSemaphoreTake(dataMutex, portMAX_DELAY);
      bool match = false;
      for (int i = 0; i < deskData.alarmCount; i++)
        if (strcmp(deskData.alarmTime[i], currentTime) == 0) { match = true; break; }
      xSemaphoreGive(dataMutex);
      if (match && !isAlarmActive && !alarmSnoozed) {
        isAlarmActive = true; alarmStartTime = millis();
        dbg("TASK_ALM", ">>> ALARM TRIGGERED <<<");
      }
      if (!match && isAlarmActive && (millis() - alarmStartTime >= 60000)) {
        isAlarmActive = false; alarmSnoozed = false; ledcWrite(BUZZER, 0);
      }
    }
    vTaskDelay(pdMS_TO_TICKS(30000));
  }
}

// ═════════════════════════════════════════════
//  SETUP
// ═════════════════════════════════════════════
void setup() {
  Serial.begin(115200);
  delay(1000);
  dbg("SETUP", "===== BOOT =====");
  dbgf("SETUP", "Free heap: %d", ESP.getFreeHeap());

  pinMode(BTN_NEXT, INPUT_PULLUP);
  pinMode(BTN_PREV, INPUT_PULLUP);
  pinMode(PIR_PIN,  INPUT);
  pinMode(LED_HIGH, OUTPUT); digitalWrite(LED_HIGH, LOW);
  pinMode(LED_MID,  OUTPUT); digitalWrite(LED_MID,  LOW);
  pinMode(LED_LOW,  OUTPUT); digitalWrite(LED_LOW,  LOW);

  ledcAttach(BUZZER, BUZZER_FREQ, BUZZER_RES);

  SPI.begin(EPD_SCK, -1, EPD_MOSI, CS);
  display.init(115200, true, 2, false);
  display.setRotation(0);
  dbg("SETUP", "Display ready");

  // ✅ CREATE MUTEXES AND QUEUE FIRST — before BLE and WiFi
  dataMutex    = xSemaphoreCreateMutex();
  displayMutex = xSemaphoreCreateMutex();
  wifiMutex    = xSemaphoreCreateMutex();
  bleMsgMutex  = xSemaphoreCreateMutex();
  displayQueue = xQueueCreate(10, sizeof(DisplayCommand));
  dbg("SETUP", "Mutexes + queue created");

  // ✅ BLE BEFORE WiFi — phone can discover immediately
  initBLE();
  dbg("SETUP", "BLE ready");

  // ✅ WiFi after BLE
  WiFi.mode(WIFI_STA);
  WiFi.setSleep(false);
  WiFi.setTxPower(WIFI_POWER_19_5dBm);
  connectWiFi();

  configTime(19800, 0, "pool.ntp.org", "time.nist.gov");
  struct tm timeinfo;
  int ntpRetry = 0;
  while (!getLocalTime(&timeinfo) && ntpRetry < 20) {
    dbgf("SETUP", "NTP %d/20", ++ntpRetry);
    delay(500);
  }
  if (getLocalTime(&timeinfo)) {
    char tbuf[40];
    strftime(tbuf, sizeof(tbuf), "%d %b %Y %H:%M:%S", &timeinfo);
    dbgf("SETUP", "NTP: %s", tbuf);
  }

  timeRefreshTimer = xTimerCreate("TimeRefresh", pdMS_TO_TICKS(60000),
                                   pdTRUE, NULL, timerTimeRefreshCallback);
  apiRefreshTimer  = xTimerCreate("APIRefresh",  pdMS_TO_TICKS(90000),
                                   pdTRUE, NULL, timerAPIRefreshCallback);

  attachInterrupt(digitalPinToInterrupt(BTN_NEXT), isrBtnNext, FALLING);
  attachInterrupt(digitalPinToInterrupt(BTN_PREV), isrBtnPrev, FALLING);

  // ✅ Add these 2 lines in setup() before xTaskCreatePinnedToCore calls:
  analogReadResolution(12);
  analogSetAttenuation(ADC_11db);
  dbg("SETUP", "ADC configured");

  esp_task_wdt_config_t wdt_config = {
    .timeout_ms     = 30000,
    .idle_core_mask = 0,
    .trigger_panic  = true
  };
  esp_task_wdt_reconfigure(&wdt_config);

  // ✅ Give battery task more stack — 4096 not 2048
  xTaskCreatePinnedToCore(taskAPI,     "API",     8192, NULL, 2, &taskAPIHandle,     0);
  xTaskCreatePinnedToCore(taskDisplay, "Display", 8192, NULL, 3, &taskDisplayHandle, 1);
  xTaskCreatePinnedToCore(taskAlarm,   "Alarm",   4096, NULL, 2, &taskAlarmHandle,   0);
  xTaskCreatePinnedToCore(taskPIR,     "PIR",     4096, NULL, 2, &taskPIRHandle,     0);
  xTaskCreatePinnedToCore(taskBuzzer,  "Buzzer",  4096, NULL, 4, &taskBuzzerHandle,  0);
  xTaskCreatePinnedToCore(taskBattery, "Battery", 4096, NULL, 1, &taskBatteryHandle, 0);
  dbg("SETUP", "All tasks created");

  dbgf("SETUP", "Free heap after: %d", ESP.getFreeHeap());
}

void loop() { vTaskDelete(NULL); }
